# ── Virgil — Environment Variables ────────────────────────────

# Cloudflare Tunnel token — from Zero Trust > Networks > Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# Encryption key for LLM API keys at rest (optional)
# If empty, auto-generates to /data/virgil.key on first run
VIRGIL_ENCRYPTION_KEY=

# Internal LLM — used for onboarding and system features
# Default model: gemini/gemini-3-flash-preview (requires Google AI API key)
# Override with any LiteLLM model string (e.g., anthropic/claude-sonnet-4-20250514)
VIRGIL_INTERNAL_LLM_MODEL=gemini/gemini-3-flash-preview
VIRGIL_INTERNAL_LLM_KEY=

# Multi-user — admin emails (comma-separated, always have admin role)
VIRGIL_ADMIN_EMAILS=admin@example.com

# Registration open/closed (default: false — closed).
# The FIRST account can always be created even when closed (bootstrap owner).
VIRGIL_REGISTRATION_OPEN=false

# Read-only REST API for external tools (OpenClaw, AI agents)
# Empty = API disabled. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
VIRGIL_API_KEY=
# Which user's data the API serves (default: first active admin)
VIRGIL_API_USER_EMAIL=
# Expose /api/noporn (intimate journal/relapse content) via the API key (default: false)
VIRGIL_API_SENSITIVE=false
